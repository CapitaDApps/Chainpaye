# Database Configuration
MONGODB_URI=mongodb://localhost:27017/chainpaye

# WhatsApp Business API Configuration
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_VERSION=v18.0

# WhatsApp Flow Encryption (Required for Flow endpoints)
PRIVATE_KEY=your_private_key_for_flow_encryption
PASSPHRASE=your_passphrase_for_private_key

# WhatsApp Flow IDs (Production)
WHATSAPP_INTRO_FLOW_ID=your_intro_flow_id
WHATSAPP_TOPUP_FLOW_ID=your_topup_flow_id
WHATSAPP_TRANSFER_FLOW_ID=your_transfer_flow_id
WHATSAPP_WITHDRAWAL_FLOW_ID=your_withdrawal_flow_id
WHATSAPP_CONVERT_FLOW_ID=your_convert_flow_id
WHATSAPP_KYC_FLOW_ID=your_kyc_flow_id
WHATSAPP_OFFRAMP_FLOW_ID=your_offramp_flow_id
WHATSAPP_PAYMENT_LINK_FLOW_ID=your_payment_link_flow_id
WHATSAPP_REFERRAL_FLOW_ID=1240916918227550
WHATSAPP_WITHDRAWAL_BUTTON_FLOW_ID=your_withdrawal_button_flow_id
WHATSAPP_USD_DEPOSIT_FLOW_ID=your_usd_deposit_flow_id
WHATSAPP_BANK_DETAILS_FLOW_ID=your_bank_details_flow_id
WHATSAPP_REFERRAL_WITHDRAWAL_FLOW_ID=your_referral_withdrawal_flow_id
WHATSAPP_ONRAMP_FLOW_ID=your_onramp_flow_id
WHATSAPP_COMPLETE_TRANSACTION_FLOW_ID=your_complete_transaction_flow_id
WHATSAPP_IMAGE_PAYMENT_FLOW_ID=your_image_payment_flow_id

# WhatsApp Flow IDs (Staging - PORT=3001)
WHATSAPP_STAGING_INTRO_FLOW_ID=your_staging_intro_flow_id
WHATSAPP_STAGING_TOPUP_FLOW_ID=your_staging_topup_flow_id
WHATSAPP_STAGING_TRANSFER_FLOW_ID=your_staging_transfer_flow_id
WHATSAPP_STAGING_WITHDRAWAL_FLOW_ID=your_staging_withdrawal_flow_id
WHATSAPP_STAGING_CONVERT_FLOW_ID=your_staging_convert_flow_id
WHATSAPP_STAGING_KYC_FLOW_ID=your_staging_kyc_flow_id
WHATSAPP_STAGING_OFFRAMP_FLOW_ID=your_staging_offramp_flow_id
WHATSAPP_STAGING_PAYMENT_LINK_FLOW_ID=your_staging_payment_link_flow_id
WHATSAPP_STAGING_REFERRAL_FLOW_ID=your_staging_referral_flow_id
WHATSAPP_STAGING_WITHDRAWAL_BUTTON_FLOW_ID=your_staging_withdrawal_button_flow_id
WHATSAPP_STAGING_USD_DEPOSIT_FLOW_ID=your_staging_usd_deposit_flow_id
WHATSAPP_STAGING_BANK_DETAILS_FLOW_ID=your_staging_bank_details_flow_id
WHATSAPP_STAGING_REFERRAL_WITHDRAWAL_FLOW_ID=your_staging_referral_withdrawal_flow_id
WHATSAPP_STAGING_ONRAMP_FLOW_ID=your_staging_onramp_flow_id
WHATSAPP_STAGING_COMPLETE_TRANSACTION_FLOW_ID=your_staging_complete_transaction_flow_id
WHATSAPP_STAGING_IMAGE_PAYMENT_FLOW_ID=your_staging_image_payment_flow_id

# OpenAI Configuration (for image payment detection)
OPENAI_API_KEY=your_openai_api_key

# Toronet Blockchain API Configuration
TORONET_API_URL=https://api.toronet.com
TORONET_ADMIN_ADDRESS=admin_username
TORONET_ADMIN_PASSWORD=admin_password

# Application Configuration
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=info
PORT=3000

# Staging access control (comma-separated WhatsApp numbers in E.164 format)
STAGING_ALLOWED_WHATSAPP_NUMBERS=+2347035428475,+2347016505681

# Security Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d
PIN_SALT_ROUNDS=12

# Transaction Configuration
MAX_TRANSACTION_AMOUNT=10000
MIN_TRANSACTION_AMOUNT=0.01
TRANSACTION_TIMEOUT=300000

# Offramp Fee Configuration
OFFRAMP_FLAT_FEE_USD=0.75
OFFRAMP_SPREAD_NGN=60
OFFRAMP_MIN_AMOUNT_NGN=5000
OFFRAMP_MAX_AMOUNT_NGN=10000000

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Notification Configuration
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# Payment Link Webhook Configuration
PAYMENT_LINK_SUCCESS_WEBHOOK_URL=h
# Crossmint Configuration
CROSSMINT_API_KEY=your_crossmint_api_key
CROSSMINT_BASE_URL=https://crossmint.com/api/2025-06-09
CROSSMINT_WEBHOOK_SECRET=your_crossmint_webhook_secret_from_dashboard

# Crossmint Admin Signer Addresses (External Wallets)
# Solana admin wallet address (for creating Solana wallets)
CROSSMINT_ADMIN_SOLANA_ADDRESS=CGz55mod1w6MtJ6DSzzG6Bi3mkd9CfJvxiqEjcJtkvGY

# EVM admin wallet address (for creating EVM-based wallets: BSC, Base, Arbitrum, etc.)
CROSSMINT_ADMIN_EVM_ADDRESS=0x9F91e934e3F2792a43Ca1Cd3f5DE7a798b4ce4fC

# Legacy admin signer address (fallback for other chains)
CROSSMINT_ADMIN_SIGNER_ADDRESS=0x9F91e934e3F2792a43Ca1Cd3f5DE7a798b4ce4fC

# Private keys for auto-signing transactions (required for external wallet signers)
# EVM private key (hex format) - corresponds to CROSSMINT_ADMIN_EVM_ADDRESS
CROSSMINT_ADMIN_EVM_PRIVATE_KEY=

# Solana private key (base58 format) - corresponds to CROSSMINT_ADMIN_SOLANA_ADDRESS  
CROSSMINT_ADMIN_SOLANA_PRIVATE_KEY=

# Receipt Generation Configuration
# For Linux servers, set the path to Chromium browser
# Example: CHROMIUM_PATH=/usr/bin/chromium-browser
# For Windows, leave empty to use bundled Chromium
CHROMIUM_PATH=/usr/bin/chromium-browser

# Referral Withdrawal System Configuration
# WhatsApp Flow IDs for referral earnings withdrawal
WHATSAPP_REFERRAL_WITHDRAWAL_FLOW_ID=your_referral_withdrawal_flow_id
WHATSAPP_STAGING_REFERRAL_WITHDRAWAL_FLOW_ID=your_staging_referral_withdrawal_flow_id

# Referral withdrawal settings
REFERRAL_WITHDRAWAL_MIN_AMOUNT=20
REFERRAL_WITHDRAWAL_FREQUENCY_DAYS=7
REFERRAL_WITHDRAWAL_CHAIN=base
REFERRAL_WITHDRAWAL_TOKEN=USDT

# Email (Zoho Mail)
SMTP_HOST=smtp.zoho.com
# SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=your_smtp_password
SMTP_FROM=


# Reset PIN Flow IDs
WHATSAPP_RESET_PIN_FLOW_ID=your_reset_pin_flow_id
WHATSAPP_STAGING_RESET_PIN_FLOW_ID=your_staging_reset_pin_flow_id

# Email Verification Flow
WHATSAPP_EMAIL_VERIFICATION_FLOW_ID=your_email_verification_flow_id
WHATSAPP_STAGING_EMAIL_VERIFICATION_FLOW_ID=your_staging_email_verification_flow_id
LINKIO_SEC_KEY=your_linkio_sec_key
