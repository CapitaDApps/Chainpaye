# Database Configuration
MONGODB_URI=mongodb://localhost:27017/chainpaye

# WhatsApp Business API Configuration
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_VERSION=v18.0

# WhatsApp Flow IDs (Production)
WHATSAPP_INTRO_FLOW_ID=your_intro_flow_id
WHATSAPP_TOPUP_FLOW_ID=your_topup_flow_id
WHATSAPP_TRANSFER_FLOW_ID=your_transfer_flow_id
WHATSAPP_WITHDRAWAL_FLOW_ID=your_withdrawal_flow_id
WHATSAPP_CONVERT_FLOW_ID=your_convert_flow_id
WHATSAPP_KYC_FLOW_ID=your_kyc_flow_id
WHATSAPP_OFFRAMP_FLOW_ID=your_offramp_flow_id
WHATSAPP_PAYMENT_LINK_FLOW_ID=your_payment_link_flow_id
WHATSAPP_REFERRAL_FLOW_ID=1240916918227550
WHATSAPP_WITHDRAWAL_BUTTON_FLOW_ID=your_withdrawal_button_flow_id

# WhatsApp Flow IDs (Staging - PORT=3001)
WHATSAPP_STAGING_INTRO_FLOW_ID=your_staging_intro_flow_id
WHATSAPP_STAGING_TOPUP_FLOW_ID=your_staging_topup_flow_id
WHATSAPP_STAGING_TRANSFER_FLOW_ID=your_staging_transfer_flow_id
WHATSAPP_STAGING_WITHDRAWAL_FLOW_ID=your_staging_withdrawal_flow_id
WHATSAPP_STAGING_CONVERT_FLOW_ID=your_staging_convert_flow_id
WHATSAPP_STAGING_KYC_FLOW_ID=your_staging_kyc_flow_id
WHATSAPP_STAGING_OFFRAMP_FLOW_ID=your_staging_offramp_flow_id
WHATSAPP_STAGING_PAYMENT_LINK_FLOW_ID=your_staging_payment_link_flow_id
WHATSAPP_STAGING_REFERRAL_FLOW_ID=your_staging_referral_flow_id
WHATSAPP_STAGING_WITHDRAWAL_BUTTON_FLOW_ID=your_staging_withdrawal_button_flow_id

# Toronet Blockchain API Configuration
TORONET_API_URL=https://api.toronet.com
TORONET_ADMIN_ADDRESS=admin_username
TORONET_ADMIN_PASSWORD=admin_password

# Application Configuration
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=info
PORT=3000

# Staging access control (comma-separated WhatsApp numbers in E.164 format)
STAGING_ALLOWED_WHATSAPP_NUMBERS=+2347035428475,+2347016505681

# Security Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d
PIN_SALT_ROUNDS=12

# Transaction Configuration
MAX_TRANSACTION_AMOUNT=10000
MIN_TRANSACTION_AMOUNT=0.01
TRANSACTION_TIMEOUT=300000

# Offramp Fee Configuration
OFFRAMP_FLAT_FEE_USD=0.75
OFFRAMP_SPREAD_NGN=60
OFFRAMP_MIN_AMOUNT_NGN=5000
OFFRAMP_MAX_AMOUNT_NGN=10000000

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Notification Configuration
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# Payment Link Webhook Configuration
PAYMENT_LINK_SUCCESS_WEBHOOK_URL=https://staging.chainpaye.com/flow/payment-link/success

# Crossmint Webhook Configuration
CROSSMINT_WEBHOOK_SECRET=your_crossmint_webhook_secret_from_dashboard

# Receipt Generation Configuration
# For Linux servers, set the path to Chromium browser
# Example: CHROMIUM_PATH=/usr/bin/chromium-browser
# For Windows, leave empty to use bundled Chromium
CHROMIUM_PATH=/usr/bin/chromium-browser
