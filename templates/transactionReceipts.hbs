<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chainpaye Receipt</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Resets and Base Styles */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #005bea; /* Main blue background */
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            -webkit-font-smoothing: antialiased;
        }

        /* The main Receipt container */
        .receipt-container {
            background-color: #fff;
            width: 100%;
            max-width: 400px;
            border-radius: 24px 24px 0 0; /* Rounded top, straight bottom for jagged edge */
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            position: relative;
        }

        /* The Jagged/Serrated Footer Effect */
        .receipt-container::after {
            content: "";
            display: block;
            position: absolute;
            bottom: -10px; /* Adjust based on circle size */
            left: 0;
            width: 100%;
            height: 20px;
            background-color: transparent;
            background-size: 20px 20px;
            background-image: radial-gradient(circle at 10px -5px, transparent 12px, #fff 13px);
        }

        /* Header Section (Logo, Amount) */
        .header {
            padding: 30px 24px;
            text-align: center;
            position: relative;
        }

        .brand-logo {
            font-weight: 900;
            font-size: 24px;
            color: #005bea;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .brand-logo img {
            width: 150px;
            height: auto;
            object-fit: contain;
        }
        .brand-icon-box {
             background: #005bea; color: white; width: 32px; height: 32px; border-radius: 8px; margin-right: 8px; display: flex; align-items: center; justify-content: center;
        }

        .transaction-summary {
            text-align: left;
        }

        /* Type Tag (e.g., DEBIT, CREDIT) */
        .type-tag {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 12px;
        }
        .tag-debit { background-color: #e3f2fd; color: #005bea; }
        .tag-credit { background-color: #e8f5e9; color: #2e7d32; }
        .tag-conversion { background-color: #fff3e0; color: #e65100; }

        /* Main Amount Display */
        .amount-large {
            font-size: 36px;
            font-weight: 800;
            color: #1a1a1a;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .conversion-header-text {
             font-size: 18px;
             color: #666;
             margin-bottom: 5px;
        }
        .conversion-amount {
             font-size: 28px;
             font-weight: 700;
             color: #1a1a1a;
        }

        .corner-logo {
            background: #005bea;
            color: white;
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 20px;
            flex-shrink: 0;
        }
        .corner-logo img {
            width: 40px;
            height: 40px;
            object-fit: contain;
            border-radius: 8px;
        }

        /* Body Section (Details List) */
        .details-body {
            background-color: #f8faff;
            padding: 24px;
            border-radius: 20px;
            margin: 0 16px 40px 16px;
        }

        /* Reusable Status Tag */
        .status-tag {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 16px;
            font-size: 12px;
            font-weight: 500;
        }
        .status-success { background-color: #dcfce7; color: #166534; }
        .status-pending { background-color: #fef9c3; color: #854d0e; }
        .status-failed { background-color: #fee2e2; color: #991b1b; }

        /* Detail Rows */
        .detail-row {
            margin-bottom: 20px;
            border-bottom: 1px solid #eee;
            padding-bottom: 16px;
        }
        .detail-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }

        .detail-label {
            font-size: 13px;
            color: #888;
            margin-bottom: 6px;
            display: block;
        }

        .detail-value {
            font-size: 15px;
            color: #1a1a1a;
            font-weight: 600;
            word-break: break-word;
            line-height: 1.4;
        }

        .detail-value.highlight {
            color: #005bea;
        }

        .detail-value.error {
            color: #dc2626;
        }
    </style>
</head>
<body>

<div class="receipt-container">
    <div class="header">
        <div class="brand-logo">
            <img src="/logo.jpg" />
            {{!-- <div class="brand-icon-box"></div> --}}
        </div>

        <div class="transaction-summary">
            <span class="type-tag {{tagClass}}">{{transactionDirection}}</span>

            {{#if isConversion}}
                <div class="conversion-header-text">Converted</div>
                 <div class="conversion-amount">{{amountFrom}}</div>
                 <div class="conversion-header-text" style="margin-top: 8px;">To</div>
                 <div class="conversion-amount">{{amountTo}}</div>
            {{else}}
                <div class="amount-large">
                    {{mainAmount}}
                    <div class="corner-logo">
                        <img src="/logo-icon.jpg" />
                    </div>
                </div>
            {{/if}}

        </div>
    </div>

    <div class="details-body">
        <div class="detail-row">
             <span class="detail-label">Transaction Type</span>
             <span class="status-tag" style="background:#e3f2fd; color:#005bea; border-radius: 6px;">{{transactionType}}</span>
        </div>

         <div class="detail-row">
             <span class="detail-label">Status</span>
             <span class="status-tag {{statusClass}}">{{status}}</span>
        </div>

        {{#if failureReason}}
        <div class="detail-row">
             <span class="detail-label">Reason</span>
             <span class="detail-value error">{{failureReason}}</span>
        </div>
        {{/if}}

        {{#if senderName}}
        <div class="detail-row">
             <span class="detail-label">Sender Name</span>
             <span class="detail-value">{{senderName}}</span>
        </div>
        {{/if}}

        {{#if sourceInstitution}}
        <div class="detail-row">
             <span class="detail-label">Source Institution</span>
             <span class="detail-value">{{sourceInstitution}}</span>
        </div>
        {{/if}}

         {{#if beneficiary}}
        <div class="detail-row">
             <span class="detail-label">Beneficiary</span>
             <span class="detail-value">{{beneficiary}}</span>
        </div>
        {{/if}}

        {{#if beneficiaryInstitution}}
        <div class="detail-row">
             <span class="detail-label">Beneficiary Institution</span>
             <span class="detail-value">{{beneficiaryInstitution}}</span>
        </div>
        {{/if}}

        {{#if exchangeRate}}
        <div class="detail-row">
             <span class="detail-label">Exchange Rate</span>
             <span class="detail-value highlight">{{exchangeRate}}</span>
        </div>
        {{/if}}

        {{#if fees}}
        <div class="detail-row">
             <span class="detail-label">Fees</span>
             <span class="detail-value">{{fees}}</span>
        </div>
        {{/if}}

        {{!-- {{#if totalAmount}}
        <div class="detail-row">
             <span class="detail-label">Total Amount</span>
             <span class="detail-value highlight">{{totalAmount}}</span>
        </div>
        {{/if}} --}}

        {{#if description}}
        <div class="detail-row">
             <span class="detail-label">Description</span>
             <span class="detail-value">{{description}}</span>
        </div>
        {{/if}}

        {{#if transactionHash}}
        <div class="detail-row">
             <span class="detail-label">Transaction Id</span>
             <span class="detail-value" style="font-size: 12px; word-break: break-all;">{{transactionHash}}</span>
        </div>
        {{/if}}

        <div class="detail-row">
             <span class="detail-label">Transaction Date</span>
             <span class="detail-value">{{transactionDate}}</span>
        </div>

        <div class="detail-row">
             <span class="detail-label">Transaction Reference</span>
             <span class="detail-value">{{transactionReference}}</span>
        </div>
    </div>

</div>

</body>
</html>
