<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chainpaye Receipt</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: transparent;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            -webkit-font-smoothing: antialiased;
        }

        .receipt-container {
            background: #ffffff;
            width: 100%;
            max-width: 600px;
            border-radius: 24px 24px 0 0;
            overflow: visible;
            position: relative;
            padding-bottom: 20px;
        }

        /* Scalloped bottom edge */
        .receipt-container::after {
            content: "";
            position: absolute;
            bottom: -20px;
            left: 0;
            width: 100%;
            height: 40px;
            background: 
                radial-gradient(circle at 20px 0, transparent 20px, #ffffff 20px) 0 0,
                radial-gradient(circle at 60px 0, transparent 20px, #ffffff 20px) 40px 0,
                radial-gradient(circle at 100px 0, transparent 20px, #ffffff 20px) 80px 0,
                radial-gradient(circle at 140px 0, transparent 20px, #ffffff 20px) 120px 0,
                radial-gradient(circle at 180px 0, transparent 20px, #ffffff 20px) 160px 0,
                radial-gradient(circle at 220px 0, transparent 20px, #ffffff 20px) 200px 0,
                radial-gradient(circle at 260px 0, transparent 20px, #ffffff 20px) 240px 0,
                radial-gradient(circle at 300px 0, transparent 20px, #ffffff 20px) 280px 0,
                radial-gradient(circle at 340px 0, transparent 20px, #ffffff 20px) 320px 0,
                radial-gradient(circle at 380px 0, transparent 20px, #ffffff 20px) 360px 0,
                radial-gradient(circle at 420px 0, transparent 20px, #ffffff 20px) 400px 0,
                radial-gradient(circle at 460px 0, transparent 20px, #ffffff 20px) 440px 0,
                radial-gradient(circle at 500px 0, transparent 20px, #ffffff 20px) 480px 0,
                radial-gradient(circle at 540px 0, transparent 20px, #ffffff 20px) 520px 0,
                radial-gradient(circle at 580px 0, transparent 20px, #ffffff 20px) 560px 0;
            background-size: 40px 40px;
            background-repeat: repeat-x;
        }

        /* Header */
        .header {
            padding: 40px 40px 20px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            object-fit: contain;
        }

        .brand-name {
            font-size: 24px;
            font-weight: 800;
            color: #1a1a1a;
            letter-spacing: -0.5px;
        }

        .receipt-label {
            font-size: 16px;
            color: #9ca3af;
            font-weight: 500;
        }

        /* Main content */
        .content {
            padding: 20px 40px 40px;
            text-align: center;
        }

        .success-message {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 16px;
        }

        .amount {
            font-size: 56px;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 12px;
            letter-spacing: -1px;
        }

        .transaction-date {
            font-size: 16px;
            color: #9ca3af;
            margin-bottom: 40px;
        }

        /* Details section */
        .details {
            text-align: left;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
            gap: 20px;
        }

        .detail-label {
            font-size: 16px;
            color: #9ca3af;
            font-weight: 500;
            flex-shrink: 0;
        }

        .detail-value {
            font-size: 16px;
            color: #1a1a1a;
            font-weight: 600;
            text-align: right;
            word-break: break-word;
        }

        /* Footer */
        .footer {
            padding: 30px 40px 40px;
            text-align: center;
        }

        .download-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #3b82f6;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            margin-bottom: 30px;
        }

        .download-icon {
            width: 20px;
            height: 20px;
        }

        .powered-by {
            font-size: 14px;
            color: #9ca3af;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
        }

        .powered-by strong {
            color: #1a1a1a;
            font-weight: 600;
        }

        .help-link {
            color: #9ca3af;
            text-decoration: none;
        }

        /* Status badge */
        .status-badge {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .status-success {
            background-color: #dcfce7;
            color: #166534;
        }

        .status-pending {
            background-color: #fef9c3;
            color: #854d0e;
        }

        .status-failed {
            background-color: #fee2e2;
            color: #991b1b;
        }
    </style>
</head>
<body>

<div class="receipt-container">
    <!-- Header -->
    <div class="header">
        <div class="logo-section">
            <img src="/logo-icon.jpg" alt="ChainPaye" class="logo-icon" />
            <span class="brand-name">CHAINPAYE</span>
        </div>
        <span class="receipt-label">Transaction Receipt</span>
    </div>

    <!-- Main Content -->
    <div class="content">
        {{#if status}}
        <span class="status-badge {{statusClass}}">{{status}}</span>
        {{/if}}

        <div class="success-message">
            {{#if isConversion}}
                Currency Conversion!
            {{else}}
                {{#if (eq status "Successful")}}
                    Payment Success!
                {{else if (eq status "Pending")}}
                    Payment Pending
                {{else}}
                    Payment {{status}}
                {{/if}}
            {{/if}}
        </div>

        <div class="amount">
            {{#if isConversion}}
                {{amountTo}}
            {{else}}
                {{mainAmount}}
            {{/if}}
        </div>

        <div class="transaction-date">{{transactionDate}}</div>

        <!-- Details -->
        <div class="details">
            {{#if beneficiary}}
            <div class="detail-row">
                <span class="detail-label">Recipient Details</span>
                <span class="detail-value">{{beneficiary}}<br>{{beneficiaryInstitution}}</span>
            </div>
            {{/if}}

            {{#if senderName}}
            <div class="detail-row">
                <span class="detail-label">Sender Details</span>
                <span class="detail-value">{{senderName}}<br>{{sourceInstitution}}</span>
            </div>
            {{/if}}

            {{#if isConversion}}
            <div class="detail-row">
                <span class="detail-label">Converted From</span>
                <span class="detail-value">{{amountFrom}}</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Exchange Rate</span>
                <span class="detail-value">{{exchangeRate}}</span>
            </div>
            {{/if}}

            {{#if fees}}
            <div class="detail-row">
                <span class="detail-label">Fees</span>
                <span class="detail-value">{{fees}}</span>
            </div>
            {{/if}}

            <div class="detail-row">
                <span class="detail-label">Transaction Id</span>
                <span class="detail-value" style="font-size: 14px; word-break: break-all;">{{transactionReference}}</span>
            </div>

            {{#if failureReason}}
            <div class="detail-row">
                <span class="detail-label">Failure Reason</span>
                <span class="detail-value" style="color: #dc2626;">{{failureReason}}</span>
            </div>
            {{/if}}
        </div>
    </div>

    <!-- Footer -->
    <div class="footer">
        <a href="#" class="download-link">
            <svg class="download-icon" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            Download PDF receipt
        </a>

        <div class="powered-by">
            <span>Powered by <strong>Chainpaye</strong></span>
            <a href="#" class="help-link">help</a>
        </div>
    </div>
</div>

</body>
</html>
