{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "CONFIRM_DETAILS": ["PIN"],
    "PIN": ["PROCESSING"],
    "PROCESSING": []
  },
  "screens": [
    {
      "id": "CONFIRM_DETAILS",
      "title": "Confirm Payment",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5000" },
        "currency": { "type": "string", "__example__": "NGN" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Review Payment Details"
          },
          {
            "type": "TextBody",
            "text": "We detected the following details from your image. Please confirm before proceeding."
          },
          {
            "type": "TextSubheading",
            "text": "Recipient"
          },
          {
            "type": "TextBody",
            "text": "${data.accountName}"
          },
          {
            "type": "TextSubheading",
            "text": "Bank"
          },
          {
            "type": "TextBody",
            "text": "${data.bankName}"
          },
          {
            "type": "TextSubheading",
            "text": "Account Number"
          },
          {
            "type": "TextBody",
            "text": "${data.accountNumber}"
          },
          {
            "type": "TextSubheading",
            "text": "Amount"
          },
          {
            "type": "TextBody",
            "text": "${data.amount} ${data.currency}"
          },
          {
            "type": "Footer",
            "label": "Confirm & Enter PIN",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "PIN" },
              "payload": {
                "accountNumber": "${data.accountNumber}",
                "accountName": "${data.accountName}",
                "bankName": "${data.bankName}",
                "bankCode": "${data.bankCode}",
                "amount": "${data.amount}",
                "currency": "${data.currency}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "PIN",
      "title": "Enter PIN",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5000" },
        "currency": { "type": "string", "__example__": "NGN" },
        "error_message": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "pin_form",
            "children": [
              {
                "type": "TextBody",
                "text": "${data.error_message}",
                "visible": "${data.error_message != null}",
                "style": { "color": "#EF4444" }
              },
              {
                "type": "TextBody",
                "text": "Enter your PIN to send ${data.amount} NGN to ${data.accountName} at ${data.bankName}."
              },
              {
                "type": "TextInput",
                "label": "PIN",
                "name": "pin",
                "required": true,
                "input-type": "password",
                "helper-text": "4-6 digit security PIN"
              },
              {
                "type": "Footer",
                "label": "Send Now",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "pin": "${form.pin}",
                    "accountNumber": "${data.accountNumber}",
                    "accountName": "${data.accountName}",
                    "bankName": "${data.bankName}",
                    "bankCode": "${data.bankCode}",
                    "amount": "${data.amount}",
                    "currency": "${data.currency}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PROCESSING",
      "title": "Processing",
      "terminal": true,
      "success": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Payment Initiated 🚀"
          },
          {
            "type": "TextBody",
            "text": "Your payment is being processed. You will receive a confirmation message shortly."
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
