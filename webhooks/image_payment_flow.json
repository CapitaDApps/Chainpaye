{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "CONFIRM_DETAILS": ["SELECT_METHOD"],
    "SELECT_METHOD": ["PIN"],
    "PIN": ["PROCESSING"],
    "PROCESSING": []
  },
  "screens": [
    {
      "id": "CONFIRM_DETAILS",
      "title": "Confirm Payment",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5000" },
        "currency": { "type": "string", "__example__": "NGN" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Review Payment Details"
          },
          {
            "type": "TextBody",
            "text": "We detected the following details from your image. Please confirm before proceeding."
          },
          {
            "type": "TextSubheading",
            "text": "Recipient"
          },
          {
            "type": "TextBody",
            "text": "${data.accountName}"
          },
          {
            "type": "TextSubheading",
            "text": "Bank"
          },
          {
            "type": "TextBody",
            "text": "${data.bankName}"
          },
          {
            "type": "TextSubheading",
            "text": "Account Number"
          },
          {
            "type": "TextBody",
            "text": "${data.accountNumber}"
          },
          {
            "type": "TextSubheading",
            "text": "Amount"
          },
          {
            "type": "TextBody",
            "text": "₦${data.amount}"
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "SELECT_METHOD" },
              "payload": {
                "accountNumber": "${data.accountNumber}",
                "accountName": "${data.accountName}",
                "bankName": "${data.bankName}",
                "bankCode": "${data.bankCode}",
                "amount": "${data.amount}",
                "currency": "${data.currency}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SELECT_METHOD",
      "title": "Payment Method",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5000" },
        "currency": { "type": "string", "__example__": "NGN" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Choose Payment Method"
          },
          {
            "type": "TextBody",
            "text": "How would you like to send ₦${data.amount} to ${data.accountName}?"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "payment_method",
            "label": "Payment Method",
            "required": true,
            "data-source": [
              {
                "id": "transfer",
                "title": "Transfer (NGN Balance)",
                "description": "Send from your NGN wallet balance"
              },
              {
                "id": "offramp",
                "title": "Offramp (Crypto)",
                "description": "Convert crypto to NGN and send"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "PIN" },
              "payload": {
                "accountNumber": "${data.accountNumber}",
                "accountName": "${data.accountName}",
                "bankName": "${data.bankName}",
                "bankCode": "${data.bankCode}",
                "amount": "${data.amount}",
                "currency": "${data.currency}",
                "paymentMethod": "${form.payment_method}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "PIN",
      "title": "Enter PIN",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5000" },
        "currency": { "type": "string", "__example__": "NGN" },
        "paymentMethod": { "type": "string", "__example__": "transfer" },
        "error_message": { "type": "string", "__example__": "" },
        "has_error": { "type": "boolean", "__example__": false }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "pin_form",
            "children": [
              {
                "type": "If",
                "condition": "${data.has_error}",
                "then": [
                  {
                    "type": "TextCaption",
                    "text": "${data.error_message}"
                  }
                ]
              },
              {
                "type": "TextBody",
                "text": "Enter your PIN to send ${data.amount} NGN to ${data.accountName} at ${data.bankName} via ${data.paymentMethod}."
              },
              {
                "type": "TextInput",
                "label": "PIN",
                "name": "pin",
                "required": true,
                "input-type": "password",
                "helper-text": "4-6 digit security PIN"
              },
              {
                "type": "Footer",
                "label": "Send Now",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "pin": "${form.pin}",
                    "accountNumber": "${data.accountNumber}",
                    "accountName": "${data.accountName}",
                    "bankName": "${data.bankName}",
                    "bankCode": "${data.bankCode}",
                    "amount": "${data.amount}",
                    "currency": "${data.currency}",
                    "paymentMethod": "${data.paymentMethod}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PROCESSING",
      "title": "Processing",
      "terminal": true,
      "success": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Payment Initiated 🚀"
          },
          {
            "type": "TextBody",
            "text": "Your payment is being processed. You will receive a confirmation message shortly."
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
