{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "CONFIRM_BANK_DETAILS": ["SELECT_ASSET_CHAIN"],
    "SELECT_ASSET_CHAIN": ["REVIEW_DETAILS"],
    "REVIEW_DETAILS": ["AUTHORIZE_PAYMENT"],
    "AUTHORIZE_PAYMENT": ["PROCESSING"],
    "PROCESSING": []
  },
  "screens": [
    {
      "id": "CONFIRM_BANK_DETAILS",
      "title": "Confirm Bank Details",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5000" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Detected Payment Details"
          },
          {
            "type": "TextBody",
            "text": "We extracted the following details from your image:"
          },
          {
            "type": "TextSubheading",
            "text": "Recipient"
          },
          {
            "type": "TextBody",
            "text": "${data.accountName}"
          },
          {
            "type": "TextSubheading",
            "text": "Bank"
          },
          {
            "type": "TextBody",
            "text": "${data.bankName}"
          },
          {
            "type": "TextSubheading",
            "text": "Account Number"
          },
          {
            "type": "TextBody",
            "text": "${data.accountNumber}"
          },
          {
            "type": "TextSubheading",
            "text": "Amount"
          },
          {
            "type": "TextBody",
            "text": "₦${data.amount}"
          },
          {
            "type": "Footer",
            "label": "Confirm & Continue",
            "on-click-action": {
              "name": "data_exchange",
              "next": { "type": "screen", "name": "SELECT_ASSET_CHAIN" },
              "payload": {
                "accountNumber": "${data.accountNumber}",
                "accountName": "${data.accountName}",
                "bankName": "${data.bankName}",
                "bankCode": "${data.bankCode}",
                "amount": "${data.amount}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SELECT_ASSET_CHAIN",
      "title": "Select Asset & Network",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5000" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Select Crypto to Sell"
          },
          {
            "type": "Form",
            "name": "asset_form",
            "children": [
              {
                "type": "Dropdown",
                "name": "currency",
                "label": "Asset to Sell",
                "required": true,
                "data-source": [
                  {
                    "id": "USDT",
                    "title": "Tether (USDT)"
                  },
                  {
                    "id": "USDC",
                    "title": "USD Coin (USDC)"
                  }
                ]
              },
              {
                "type": "Dropdown",
                "name": "network",
                "label": "Select Network",
                "required": true,
                "data-source": [
                  {
                    "id": "BEP20",
                    "title": "BNB Smart Chain (BEP20)"
                  },
                  {
                    "id": "SOL",
                    "title": "Solana (SOL)"
                  },
                  {
                    "id": "BASE",
                    "title": "Base Network"
                  },
                  {
                    "id": "ARBITRUM",
                    "title": "Arbitrum"
                  }
                ]
              },
              {
                "type": "Footer",
                "label": "Get Quote",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "accountNumber": "${data.accountNumber}",
                    "accountName": "${data.accountName}",
                    "bankName": "${data.bankName}",
                    "bankCode": "${data.bankCode}",
                    "amount": "${data.amount}",
                    "currency": "${form.currency}",
                    "network": "${form.network}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "REVIEW_DETAILS",
      "title": "Review Payment",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5,000" },
        "currency": { "type": "string", "__example__": "USDC" },
        "network": { "type": "string", "__example__": "BASE" },
        "sellAmountUsd": { "type": "string", "__example__": "3.73" },
        "rate": { "type": "string", "__example__": "₦1,460" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Review Details"
          },
          {
            "type": "TextBody",
            "text": "`'Recipient: '${data.accountName}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Bank: '${data.bankName}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Account: '${data.accountNumber}''`"
          },
          {
            "type": "TextBody",
            "text": "`'To Receive: ₦'${data.amount}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Selling: '${data.sellAmountUsd}' '${data.currency}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Network: '${data.network}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Rate: 1 '${data.currency}' = '${data.rate}' (with spread)'`"
          },
          {
            "type": "Footer",
            "label": "Proceed to Payment",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "accountNumber": "${data.accountNumber}",
                "accountName": "${data.accountName}",
                "bankName": "${data.bankName}",
                "bankCode": "${data.bankCode}",
                "amount": "${data.amount}",
                "currency": "${data.currency}",
                "network": "${data.network}",
                "sellAmountUsd": "${data.sellAmountUsd}",
                "rate": "${data.rate}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "AUTHORIZE_PAYMENT",
      "title": "Authorize Payment",
      "data": {
        "accountNumber": { "type": "string", "__example__": "0123456789" },
        "accountName": { "type": "string", "__example__": "John Doe" },
        "bankName": { "type": "string", "__example__": "GTBank" },
        "bankCode": { "type": "string", "__example__": "000013" },
        "amount": { "type": "string", "__example__": "5,000" },
        "currency": { "type": "string", "__example__": "USDC" },
        "network": { "type": "string", "__example__": "BASE" },
        "sellAmountUsd": { "type": "string", "__example__": "3.73" },
        "totalAmountUsd": { "type": "string", "__example__": "4.48" },
        "error_message": { "type": "string", "__example__": "" },
        "has_error": { "type": "boolean", "__example__": false }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Authorize Payment"
          },
          {
            "type": "If",
            "condition": "${data.has_error}",
            "then": [
              {
                "type": "TextCaption",
                "text": "${data.error_message}"
              }
            ]
          },
          {
            "type": "TextBody",
            "text": "`'To Receive: ₦'${data.amount}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Selling: '${data.sellAmountUsd}' '${data.currency}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Fee: $0.75 USD'`"
          },
          {
            "type": "TextBody",
            "text": "`'Total: '${data.totalAmountUsd}' '${data.currency}''`"
          },
          {
            "type": "TextBody",
            "text": "`'Network: '${data.network}''`"
          },
          {
            "type": "TextBody",
            "text": "Enter PIN to Confirm"
          },
          {
            "type": "Form",
            "name": "pin_form",
            "children": [
              {
                "type": "TextInput",
                "name": "pin",
                "label": "4-6 Digit PIN",
                "required": true,
                "input-type": "password",
                "min-chars": 4,
                "max-chars": 6
              },
              {
                "type": "Footer",
                "label": "Sell & Withdraw",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "pin": "${form.pin}",
                    "accountNumber": "${data.accountNumber}",
                    "accountName": "${data.accountName}",
                    "bankName": "${data.bankName}",
                    "bankCode": "${data.bankCode}",
                    "amount": "${data.amount}",
                    "currency": "${data.currency}",
                    "network": "${data.network}",
                    "sellAmountUsd": "${data.sellAmountUsd}",
                    "totalAmountUsd": "${data.totalAmountUsd}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PROCESSING",
      "title": "Processing",
      "terminal": true,
      "success": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Funds are underway! 🚀"
          },
          {
            "type": "TextBody",
            "text": "Your payment has been initiated. The funds usually hit the bank account in under 50 seconds."
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "status": "payment_initiated",
                "result": "success"
              }
            }
          }
        ]
      }
    }
  ]
}
