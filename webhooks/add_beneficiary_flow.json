{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "SELECT_COUNTRY": ["SELECT_PAYMENT_METHOD"],
    "SELECT_PAYMENT_METHOD": ["BANK_DETAILS"],
    "BANK_DETAILS": ["CONFIRM"],
    "CONFIRM": ["PIN"],
    "PIN": ["SUCCESS"],
    "SUCCESS": []
  },
  "screens": [
    {
      "id": "SELECT_COUNTRY",
      "title": "Add Beneficiary",
      "data": {
        "error_message": {
          "type": "string",
          "__example__": ""
        },
        "has_error": {
          "type": "boolean",
          "__example__": false
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "country_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Add Beneficiary"
              },
              {
                "type": "TextBody",
                "text": "Select the country of the bank account you want to add."
              },
              {
                "type": "TextBody",
                "text": "${data.error_message}",
                "visible": "${data.has_error}"
              },
              {
                "type": "Dropdown",
                "label": "Country",
                "name": "country",
                "required": true,
                "data-source": [
                  { "id": "ghana", "title": "Ghana" },
                  { "id": "kenya", "title": "Kenya" }
                ]
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "country": "${form.country}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SELECT_PAYMENT_METHOD",
      "title": "Payment Method",
      "data": {
        "country": {
          "type": "string",
          "__example__": "ghana"
        },
        "payment_methods": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        },
        "error_message": {
          "type": "string",
          "__example__": ""
        },
        "has_error": {
          "type": "boolean",
          "__example__": false
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "payment_method_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Select Payment Method"
              },
              {
                "type": "TextBody",
                "text": "${data.error_message}",
                "visible": "${data.has_error}"
              },
              {
                "type": "Dropdown",
                "label": "Payment Method",
                "name": "payment_method",
                "required": true,
                "data-source": "${data.payment_methods}"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "country": "${data.country}",
                    "payment_method": "${form.payment_method}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "BANK_DETAILS",
      "title": "Bank Details",
      "data": {
        "country": {
          "type": "string",
          "__example__": "ghana"
        },
        "payment_method": {
          "type": "string",
          "__example__": "mtn_momo_gh"
        },
        "payment_method_name": {
          "type": "string",
          "__example__": "MTN Mobile Money"
        },
        "is_mobile_money": {
          "type": "boolean",
          "__example__": true
        },
        "is_bank_transfer": {
          "type": "boolean",
          "__example__": false
        },
        "banks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        },
        "error_message": {
          "type": "string",
          "__example__": ""
        },
        "has_error": {
          "type": "boolean",
          "__example__": false
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "bank_details_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Account Details"
              },
              {
                "type": "TextBody",
                "text": "Payment Method: ${data.payment_method_name}"
              },
              {
                "type": "TextBody",
                "text": "${data.error_message}",
                "visible": "${data.has_error}"
              },
              {
                "type": "Dropdown",
                "label": "Bank",
                "name": "bank_id",
                "required": true,
                "data-source": "${data.banks}"
              },
              {
                "type": "TextInput",
                "label": "Mobile Money Phone Number",
                "name": "phone_number",
                "required": false,
                "input-type": "phone",
                "visible": "${data.is_mobile_money}"
              },
              {
                "type": "TextInput",
                "label": "Account Number",
                "name": "account_number",
                "required": false,
                "input-type": "number",
                "visible": "${data.is_bank_transfer}"
              },
              {
                "type": "TextInput",
                "label": "Account Name",
                "name": "account_name",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "Dropdown",
                "label": "Destination",
                "name": "destination",
                "required": true,
                "data-source": [
                  { "id": "first_party", "title": "First Party (My Account)" },
                  { "id": "third_party", "title": "Third Party (Someone Else)" }
                ]
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "country": "${data.country}",
                    "payment_method": "${data.payment_method}",
                    "phone_number": "${form.phone_number}",
                    "bank_id": "${form.bank_id}",
                    "account_number": "${form.account_number}",
                    "account_name": "${form.account_name}",
                    "destination": "${form.destination}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "CONFIRM",
      "title": "Confirm Details",
      "data": {
        "country": { "type": "string", "__example__": "ghana" },
        "payment_method": { "type": "string", "__example__": "mtn_momo_gh" },
        "payment_method_name": { "type": "string", "__example__": "MTN Mobile Money" },
        "phone_number": { "type": "string", "__example__": "+233123456789" },
        "bank_name": { "type": "string", "__example__": "Absa Bank" },
        "bank_code": { "type": "string", "__example__": "03" },
        "account_number": { "type": "string", "__example__": "9039221043" },
        "account_name": { "type": "string", "__example__": "John Doe" },
        "destination": { "type": "string", "__example__": "First Party (My Account)" },
        "destination_id": { "type": "string", "__example__": "first_party" },
        "resolved_account_name": { "type": "string", "__example__": "JOHN DOE" },
        "has_phone": { "type": "boolean", "__example__": false },
        "has_account": { "type": "boolean", "__example__": true }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "confirm_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Confirm Beneficiary"
              },
              {
                "type": "TextSubheading",
                "text": "Account Details"
              },
              {
                "type": "TextBody",
                "text": "`'Payment Method: '${data.payment_method_name}''`"
              },
              {
                "type": "TextBody",
                "text": "`'Phone Number: '${data.phone_number}''`",
                "visible": "${data.has_phone}"
              },
              {
                "type": "TextBody",
                "text": "`'Bank: '${data.bank_name}''`",
                "visible": "${data.has_account}"
              },
              {
                "type": "TextBody",
                "text": "`'Account Number: '${data.account_number}''`",
                "visible": "${data.has_account}"
              },
              {
                "type": "TextBody",
                "text": "`'Account Name: '${data.resolved_account_name}''`"
              },
              {
                "type": "TextBody",
                "text": "`'Destination: '${data.destination}''`"
              },
              {
                "type": "Footer",
                "label": "Add Beneficiary",
                "on-click-action": {
                  "name": "navigate",
                  "next": { "type": "screen", "name": "PIN" },
                  "payload": {
                    "country": "${data.country}",
                    "payment_method": "${data.payment_method}",
                    "phone_number": "${data.phone_number}",
                    "bank_name": "${data.bank_name}",
                    "bank_code": "${data.bank_code}",
                    "account_number": "${data.account_number}",
                    "account_name": "${data.resolved_account_name}",
                    "destination": "${data.destination_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PIN",
      "title": "Enter PIN",
      "data": {
        "country": { "type": "string", "__example__": "ghana" },
        "payment_method": { "type": "string", "__example__": "mtn_momo_gh" },
        "phone_number": { "type": "string", "__example__": "+233123456789" },
        "bank_name": { "type": "string", "__example__": "Absa Bank" },
        "bank_code": { "type": "string", "__example__": "03" },
        "account_number": { "type": "string", "__example__": "9039221043" },
        "account_name": { "type": "string", "__example__": "John Doe" },
        "destination": { "type": "string", "__example__": "first_party" },
        "error_message": { "type": "string", "__example__": "" },
        "has_error": { "type": "boolean", "__example__": false }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "pin_form",
            "children": [
              {
                "type": "TextBody",
                "text": "${data.error_message}",
                "visible": "${data.has_error}"
              },
              {
                "type": "TextBody",
                "text": "Enter your 4-digit PIN to confirm adding this beneficiary."
              },
              {
                "type": "TextInput",
                "label": "PIN",
                "name": "pin",
                "required": true,
                "input-type": "password"
              },
              {
                "type": "Footer",
                "label": "Confirm",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "pin": "${form.pin}",
                    "country": "${data.country}",
                    "payment_method": "${data.payment_method}",
                    "phone_number": "${data.phone_number}",
                    "bank_name": "${data.bank_name}",
                    "bank_code": "${data.bank_code}",
                    "account_number": "${data.account_number}",
                    "account_name": "${data.account_name}",
                    "destination": "${data.destination}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "Beneficiary Added",
      "terminal": true,
      "success": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Beneficiary Added"
          },
          {
            "type": "TextBody",
            "text": "Your beneficiary has been saved successfully."
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
