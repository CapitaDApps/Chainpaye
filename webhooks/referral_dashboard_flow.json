{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "REFERRAL_DASHBOARD": ["SHARE_REFERRAL", "WITHDRAWAL_REQUEST", "WITHDRAWAL_HISTORY"],
    "SHARE_REFERRAL": [],
    "WITHDRAWAL_REQUEST": ["WITHDRAWAL_CONFIRMATION"],
    "WITHDRAWAL_CONFIRMATION": [],
    "WITHDRAWAL_HISTORY": []
  },
  "screens": [
    {
      "id": "REFERRAL_DASHBOARD",
      "title": "Referral Dashboard",
      "terminal": false,
      "data": {
        "referralCode": {
          "type": "string",
          "__example__": "ABC123"
        },
        "referralLink": {
          "type": "string",
          "__example__": "wa.me/1234567890?text=start%20ABC123"
        },
        "currentBalance": {
          "type": "string",
          "__example__": "125.50"
        },
        "totalEarned": {
          "type": "string",
          "__example__": "450.75"
        },
        "totalReferred": {
          "type": "number",
          "__example__": 15
        },
        "totalVolume": {
          "type": "string",
          "__example__": "12500.00"
        },
        "totalFees": {
          "type": "string",
          "__example__": "125.00"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "dashboard_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "� Referral Dashboard"
              },
              {
                "type": "TextSubheading",
                "text": "🔗 Your Referral Code"
              },
              {
                "type": "TextBody",
                "text": "`${data.referralCode}`"
              },
              {
                "type": "TextSubheading",
                "text": "💰 Current Balance"
              },
              {
                "type": "TextBody",
                "text": "`'$'${data.currentBalance}`"
              },
              {
                "type": "TextSubheading",
                "text": "📈 Total Earned"
              },
              {
                "type": "TextBody",
                "text": "`'$'${data.totalEarned}`"
              },
              {
                "type": "TextSubheading",
                "text": "👥 Total Referred"
              },
              {
                "type": "TextBody",
                "text": "`${data.totalReferred}' users'`"
              },
              {
                "type": "TextSubheading",
                "text": "💵 Total Volume"
              },
              {
                "type": "TextBody",
                "text": "`'$'${data.totalVolume}`"
              },
              {
                "type": "TextSubheading",
                "text": "💸 Total Fees"
              },
              {
                "type": "TextBody",
                "text": "`'$'${data.totalFees}`"
              },
              {
                "type": "RadioButtonsGroup",
                "label": "What would you like to do?",
                "name": "action_choice",
                "data-source": [
                  {
                    "id": "share",
                    "title": "🔗 Share Referral"
                  },
                  {
                    "id": "withdraw",
                    "title": "💸 Request Withdrawal"
                  },
                  {
                    "id": "history",
                    "title": "📋 View History"
                  }
                ],
                "required": true
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "action": "${form.action_choice}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SHARE_REFERRAL",
      "title": "Share Referral",
      "terminal": true,
      "success": true,
      "data": {
        "referralCode": {
          "type": "string",
          "__example__": "ABC123"
        },
        "referralLink": {
          "type": "string",
          "__example__": "wa.me/1234567890?text=start%20ABC123"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "🔗 Share Your Referral"
          },
          {
            "type": "TextSubheading",
            "text": "Your Referral Code"
          },
          {
            "type": "TextBody",
            "text": "`${data.referralCode}`"
          },
          {
            "type": "TextCaption",
            "text": "Copy and share this code with friends"
          },
          {
            "type": "TextSubheading",
            "text": "Your Referral Link"
          },
          {
            "type": "TextBody",
            "text": "`${data.referralLink}`"
          },
          {
            "type": "TextCaption",
            "text": "Share this link to make it easy for friends to sign up"
          },
          {
            "type": "TextSubheading",
            "text": "💡 How to Earn"
          },
          {
            "type": "TextBody",
            "text": "1. Share your referral link\n2. Friends sign up using link\n3. Earn 1% of their offramp\n4. Credited for 30 days"
          },
          {
            "type": "TextSubheading",
            "text": "Withdrawal Info"
          },
          {
            "type": "TextBody",
            "text": "• Min: $20\n• To: BNB Wallet\n• Time: 24-48 hours"
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "action": "share_completed"
              }
            }
          }
        ]
      }
    },
    {
      "id": "WITHDRAWAL_REQUEST",
      "title": "Request Withdrawal",
      "terminal": false,
      "data": {
        "currentBalance": {
          "type": "string",
          "__example__": "125.50"
        },
        "bnbWalletAddress": {
          "type": "string",
          "__example__": "0x1234...5678"
        },
        "canWithdraw": {
          "type": "boolean",
          "__example__": true
        },
        "error_message": {
          "type": "string",
          "__example__": ""
        },
        "has_error": {
          "type": "boolean",
          "__example__": false
        },
        "insufficientBalance": {
          "type": "boolean",
          "__example__": false
        },
        "withdrawalLimitReached": {
          "type": "boolean",
          "__example__": false
        },
        "minWithdrawal": {
          "type": "string",
          "__example__": "20.00"
        },
        "lastWithdrawalDate": {
          "type": "string",
          "__example__": ""
        },
        "daysRemaining": {
          "type": "string",
          "__example__": "0"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "withdrawal_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "💸 Request Withdrawal"
              },
              {
                "type": "TextSubheading",
                "text": "Current Balance"
              },
              {
                "type": "TextBody",
                "text": "`'$'${data.currentBalance}`"
              },
              {
                "type": "TextSubheading",
                "text": "Destination"
              },
              {
                "type": "TextBody",
                "text": "`'BNB Wallet: '${data.bnbWalletAddress}`"
              },
              {
                "type": "If",
                "condition": "${data.has_error}",
                "then": [
                  {
                    "type": "TextBody",
                    "text": "`'❌ '${data.error_message}`"
                  }
                ]
              },
              {
                "type": "If",
                "condition": "${data.canWithdraw}",
                "then": [
                  {
                    "type": "TextInput",
                    "label": "Amount (USD)",
                    "name": "withdrawal_amount",
                    "input-type": "number",
                    "required": true,
                    "helper-text": "Enter amount"
                  },
                  {
                    "type": "TextSubheading",
                    "text": "⚠️ Important"
                  },
                  {
                    "type": "TextBody",
                    "text": "`'• Min: $'${data.minWithdrawal}'\n• Max: $'${data.currentBalance}'\n• Time: 24-48 hours\n• To: BNB Wallet\n• Limit: Once per 7 days'`"
                  }
                ],
                "else": [
                  {
                    "type": "If",
                    "condition": "${data.insufficientBalance}",
                    "then": [
                      {
                        "type": "TextBody",
                        "text": "`'❌ Insufficient Balance\n\nCurrent: $'${data.currentBalance}'\nRequired: $'${data.minWithdrawal}'\n\nKeep referring to earn more!\nYou earn 1% of offramp transactions.'`"
                      }
                    ],
                    "else": [
                      {
                        "type": "TextBody",
                        "text": "`'⏰ Withdrawal Limit\n\nOnce per 7 days only.\n\nLast: '${data.lastWithdrawalDate}'\nDays left: '${data.daysRemaining}`"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "withdrawal_amount": "${form.withdrawal_amount}",
                "can_withdraw": "${data.canWithdraw}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "WITHDRAWAL_CONFIRMATION",
      "title": "Withdrawal Confirmed",
      "terminal": true,
      "success": true,
      "data": {
        "withdrawalAmount": {
          "type": "string",
          "__example__": "50.00"
        },
        "requestDate": {
          "type": "string",
          "__example__": "Jan 15, 2024"
        },
        "bnbWalletAddress": {
          "type": "string",
          "__example__": "0x1234...5678"
        },
        "newBalance": {
          "type": "string",
          "__example__": "75.50"
        },
        "nextWithdrawalDate": {
          "type": "string",
          "__example__": "Jan 22, 2024"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "✅ Withdrawal Submitted"
          },
          {
            "type": "TextSubheading",
            "text": "Request Details"
          },
          {
            "type": "TextBody",
            "text": "`'Amount: $'${data.withdrawalAmount}'\nStatus: Under Review\nRequested: '${data.requestDate}'\nDestination: BNB Wallet'`"
          },
          {
            "type": "TextSubheading",
            "text": "Wallet Address"
          },
          {
            "type": "TextBody",
            "text": "`${data.bnbWalletAddress}`"
          },
          {
            "type": "TextSubheading",
            "text": "⏰ Processing Time"
          },
          {
            "type": "TextBody",
            "text": "24-48 hours"
          },
          {
            "type": "TextSubheading",
            "text": "What Happens Next?"
          },
          {
            "type": "TextBody",
            "text": "1. Under review\n2. Sent to BNB wallet\n3. Notification sent"
          },
          {
            "type": "TextSubheading",
            "text": "New Balance"
          },
          {
            "type": "TextBody",
            "text": "`'$'${data.newBalance}`"
          },
          {
            "type": "TextSubheading",
            "text": "Next Withdrawal"
          },
          {
            "type": "TextBody",
            "text": "`${data.nextWithdrawalDate}' (7 days)'`"
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "action": "withdrawal_completed"
              }
            }
          }
        ]
      }
    },
    {
      "id": "WITHDRAWAL_HISTORY",
      "title": "Withdrawal History",
      "terminal": true,
      "success": true,
      "data": {
        "historyText": {
          "type": "string",
          "__example__": "$50.00 - Under Review 🔄\nJan 15, 2024\nBNB Wallet\n\n$100.00 - Completed ✅\nJan 8, 2024\nPaid: Jan 9, 2024"
        },
        "hasWithdrawals": {
          "type": "boolean",
          "__example__": true
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "📋 Withdrawal History"
          },
          {
            "type": "If",
            "condition": "${data.hasWithdrawals}",
            "then": [
              {
                "type": "TextSubheading",
                "text": "Recent Withdrawals"
              },
              {
                "type": "TextBody",
                "text": "`${data.historyText}`"
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "No withdrawals yet.\n\nMake your first withdrawal when you have $20!"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "action": "history_viewed"
              }
            }
          }
        ]
      }
    }
  ]
}
