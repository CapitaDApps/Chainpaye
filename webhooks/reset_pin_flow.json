{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "COLLECT_EMAIL": ["SUCCESS"],
    "SUCCESS": []
  },
  "screens": [
    {
      "id": "COLLECT_EMAIL",
      "title": "Reset PIN",
      "data": {
        "error_message": {
          "type": "string",
          "__example__": ""
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "email_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Reset Your PIN"
              },
              {
                "type": "TextBody",
                "text": "Enter your email address and we'll send you a secure link to reset your PIN. The link expires in 15 minutes."
              },
              {
                "type": "TextInput",
                "label": "Email Address",
                "name": "email",
                "required": true,
                "input-type": "email",
                "helper-text": "Enter a valid email address"
              },
              {
                "type": "EmbeddedLink",
                "text": "${data.error_message}",
                "visible": "${data.error_message}",
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "type": "screen",
                    "name": "COLLECT_EMAIL"
                  },
                  "payload": {}
                }
              },
              {
                "type": "Footer",
                "label": "Send Reset Link",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "email": "${form.email}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "Email Sent",
      "terminal": true,
      "success": true,
      "data": {
        "message": {
          "type": "string",
          "__example__": "A reset link has been sent to your email."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Check Your Email ✉️"
          },
          {
            "type": "TextBody",
            "text": "${data.message}"
          },
          {
            "type": "TextBody",
            "text": "Click the link in the email to set a new PIN. The link expires in 15 minutes."
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
