{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "TOPUP_WALLET": ["RETURN_TO_CHAT"],
    "RETURN_TO_CHAT": []
  },
  "screens": [
    {
      "id": "TOPUP_WALLET",
      "title": "USD Deposit",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "usd_deposit_form",
            "children": [
              {
                "type": "TextInput",
                "label": "Amount (USD)",
                "name": "amount",
                "required": true,
                "input-type": "number",
                "helper-text": "Enter USD amount (e.g. 100.00)"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "amount": "${form.amount}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "RETURN_TO_CHAT",
      "title": "Return to Chat",
      "terminal": true,
      "success": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Return to Chat 💬"
          },
          {
            "type": "TextBody",
            "text": "Please return to the chat to get your transaction details and complete your USD deposit."
          },
          {
            "type": "Footer",
            "label": "Return to Chat",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "status": "return_to_chat"
              }
            }
          }
        ]
      }
    }
  ]
}