# SMS Service Configuration
# Choose one SMS provider: twilio, termii, aws, or mock

# SMS Provider Selection
SMS_PROVIDER=mock  # Change to: twilio, termii, aws, or mock

# ==============================================
# TWILIO SMS CONFIGURATION (Global)
# ==============================================
# Sign up at: https://www.twilio.com/
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890  # Your Twilio phone number

# ==============================================
# TERMII SMS CONFIGURATION (Nigeria/Africa)
# ==============================================
# Sign up at: https://termii.com/
# Get API key from: https://accounts.termii.com/
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=ChainPaye  # Your sender ID (max 11 characters)

# ==============================================
# AWS SNS SMS CONFIGURATION
# ==============================================
# Configure AWS credentials and region
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# ==============================================
# MOCK SMS (For Testing)
# ==============================================
# No configuration needed - logs messages to console

# ==============================================
# EXISTING CONFIGURATION (Keep your current values)
# ==============================================
MONGO_DB_URI=your_mongodb_uri_here
VERIFY_TOKEN=your_verify_token_here
BUSINESS_PHONE_NUMBER_ID=your_business_phone_id_here
GRAPH_API_TOKEN=your_graph_api_token_here
# ... rest of your existing environment variables